{
  "name": "@forgeframe/core",
  "version": "0.1.1",
  "description": "ForgeFrame routing engine — tier-based model dispatch with provider registry",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist-cjs/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/notaprompt/forgeframe.git",
    "directory": "packages/core"
  },
  "files": ["dist/", "dist-cjs/"],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist-cjs/package.json','{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "build:cjs": "tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist-cjs/package.json','{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
