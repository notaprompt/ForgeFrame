{
  "name": "@forgeframe/server",
  "version": "0.1.0",
  "description": "MCP memory server for ForgeFrame — persistent semantic memory for any MCP client",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "forgeframe-memory": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/notaprompt/forgeframe.git",
    "directory": "packages/server"
  },
  "engines": { "node": ">=20.0.0" },
  "keywords": ["mcp", "mcp-server", "memory", "sqlite", "local-first"],
  "files": ["dist/"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@forgeframe/memory": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
