session_name "forge"
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
        children
    }
    tab name="1" focus=true {
        pane split_direction="vertical" {
            pane size="80%" name="claude" focus=true start_suspended=false {
                command "claude"
            }
            pane split_direction="horizontal" size="20%" {
                pane size="60%" name="forgeframe" start_suspended=false {
                    command "/bin/bash"
                    args "-c" "$FORGE_DIR/scripts/forge-display.sh"
                }
                pane size="40%" name="shell" start_suspended=false
            }
        }
    }
}
